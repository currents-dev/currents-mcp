{
  "name": "@currents/mcp",
  "type": "module",
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "keywords": [
    "currents",
    "mcp-server",
    "playwright",
    "dashboard",
    "reporting"
  ],
  "bin": "./dist/index.mjs",
  "version": "2.3.2",
  "description": "Currents MCP server",
  "main": "./dist/api.cjs",
  "module": "./dist/api.mjs",
  "types": "./dist/api.d.mts",
  "exports": {
    ".": {
      "types": "./dist/api.d.mts",
      "import": "./dist/api.mjs",
      "require": "./dist/api.cjs"
    }
  },
  "scripts": {
    "build": "tsdown && chmod 755 dist/index.mjs",
    "publish:mcp": "npm run publish:npm",
    "publish:npm": "npm run rm && npm run build && ./publish.cjs",
    "start": "node dist/index.mjs",
    "rm": "rm -rf dist",
    "prepare": "git config core.hooksPath mcp-server/scripts/hooks",
    "sync-readme": "node scripts/sync-readme-tools.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "author": "Currents Software Inc",
  "homepage": "https://currents.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/currents-dev/currents-mcp.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^12.1.0",
    "pino": "^9.9.5",
    "pino-pretty": "^13.1.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^20.19.0",
    "release-it": "^20.0.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
